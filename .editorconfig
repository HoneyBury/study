root = true

[*]
charset = utf-8-bom
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

[*.json]
charset = utf-8

[*.{py,sh,bat,ps1}]
charset = utf-8
indent_size = 4

[Makefile]
indent_style = tab
